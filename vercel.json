{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/e/:id",
      "destination": "https://semear-api-pl65.onrender.com/api/public/eventos/:id/compartilhar"
    },
    {
      "source": "/api/public/eventos/:id/banner",
      "destination": "https://semear-api-pl65.onrender.com/api/public/eventos/:id/banner"
    },
    {
      "source": "/api/eventos/:id/banner",
      "destination": "https://semear-api-pl65.onrender.com/api/eventos/:id/banner"
    },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/landing/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|robots\\.txt|llms\\.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
