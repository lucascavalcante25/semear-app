# Frontend
VITE_API_URL=http://localhost:8080
# URL pública do site (SEO: canonical, og:url, sitemap)
VITE_SITE_URL=http://localhost:5173
# Google Analytics 4 — ID de medição (G-XXXXXXXXXX). Ative com Google Tag Assistant.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Search Console — código de verificação da meta tag HTML
# VITE_GOOGLE_SITE_VERIFICATION=seu-codigo-aqui

# PostgreSQL local
SEMEAR_DB_URL=jdbc:postgresql://localhost:5432/semearDB
SEMEAR_DB_USER=postgres
SEMEAR_DB_PASSWORD=sua_senha_postgres

# =============================================================================
# E-mail — Brevo (recomendado, plano free ~300 e-mails/dia)
# https://www.brevo.com → SMTP & API → gerar chaves
# =============================================================================
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-login@smtp-brevo.com
SPRING_MAIL_PASSWORD=sua-chave-smtp-brevo

# Remetente verificado no Brevo (Configurações → Remetentes)
SEMEAR_MAIL_FROM=willtechsolutionsdev@gmail.com

# URL pública do frontend (dev / prod)
SEMEAR_MAIL_BASE_URL=http://localhost:5173

# API Brevo — preferencial (MailService usa API antes do SMTP)
SEMEAR_BREVO_API_KEY=sua-chave-api-brevo

# Recuperação por SMS — requer créditos pré-pagos no Brevo (desativado por padrão)
SEMEAR_SMS_ENABLED=false
SEMEAR_SMS_SENDER=MinhaIgreja

# =============================================================================
# Push Notifications (Firebase Cloud Messaging) — opt-in, desabilitado por padrão
# Guia completo: docs/PUSH-NOTIFICATIONS.md
# =============================================================================
# SEMEAR_PUSH_ENABLED=false
# SEMEAR_FIREBASE_PROJECT_ID=semear-push
# SEMEAR_FIREBASE_VAPID_PUBLIC_KEY=
# SEMEAR_FIREBASE_SERVICE_ACCOUNT=../secrets/semear-push-firebase.json
# SEMEAR_PUSH_TESTE_ENABLED=true

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=semear-push.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=semear-push
# VITE_FIREBASE_STORAGE_BUCKET=semear-push.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# =============================================================================
# Integrações — Louvores (letras)
# LRCLIB: gratuito, sem chave — https://lrclib.net/docs
# Genius (opcional): https://genius.com/api-clients
# SEMEAR_GENIUS_ACCESS_TOKEN=
