# Frontend
VITE_API_URL=http://localhost:8080

# PostgreSQL local
SEMEAR_DB_URL=jdbc:postgresql://localhost:5432/semearDB
SEMEAR_DB_USER=postgres
SEMEAR_DB_PASSWORD=sua_senha_postgres

# SMTP (Brevo ou outro provedor) — copie para .env e preencha
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-login@smtp-brevo.com
SPRING_MAIL_PASSWORD=sua-chave-smtp

# E-mail remetente verificado no Brevo (Configurações > Remetentes)
SEMEAR_MAIL_FROM=seu-email@dominio.com

# URL pública do app (dev: localhost; prod: URL do frontend)
SEMEAR_MAIL_BASE_URL=http://localhost:5173

# SMS via Brevo (opcional — fallback quando usuário não tem e-mail)
SEMEAR_SMS_ENABLED=false
SEMEAR_SMS_SENDER=Semear
SEMEAR_BREVO_API_KEY=sua-chave-api-brevo
