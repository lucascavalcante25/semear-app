# Frontend
VITE_API_URL=http://localhost:8080

# PostgreSQL local
SEMEAR_DB_URL=jdbc:postgresql://localhost:5432/semearDB
SEMEAR_DB_USER=postgres
SEMEAR_DB_PASSWORD=sua_senha_postgres

# =============================================================================
# E-mail — Brevo (recomendado, plano free ~300 e-mails/dia)
# https://www.brevo.com → SMTP & API → gerar chaves
# =============================================================================
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-login@smtp-brevo.com
SPRING_MAIL_PASSWORD=sua-chave-smtp-brevo

# Remetente verificado no Brevo (Configurações → Remetentes)
SEMEAR_MAIL_FROM=willtechsolutionsdev@gmail.com

# URL pública do frontend (dev / prod)
SEMEAR_MAIL_BASE_URL=http://localhost:5173

# API Brevo — preferencial (MailService usa API antes do SMTP)
SEMEAR_BREVO_API_KEY=sua-chave-api-brevo

# Ative quando quiser oferecer recuperação por SMS (usa a mesma SEMEAR_BREVO_API_KEY)
SEMEAR_SMS_ENABLED=true
SEMEAR_SMS_SENDER=MinhaIgreja
