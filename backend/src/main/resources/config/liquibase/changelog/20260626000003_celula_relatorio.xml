<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260626000003-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="celula_relatorio"/></not>
        </preConditions>
        <createTable tableName="celula_relatorio">
            <column name="id" type="bigint"><constraints primaryKey="true" nullable="false"/></column>
            <column name="celula_id" type="bigint"><constraints nullable="false"/></column>
            <column name="igreja_id" type="bigint"><constraints nullable="false"/></column>
            <column name="data_reuniao" type="date"><constraints nullable="false"/></column>
            <column name="presentes" type="integer"><constraints nullable="false"/></column>
            <column name="visitantes" type="integer"><constraints nullable="false"/></column>
            <column name="observacao" type="${clobType}"/>
            <column name="criado_em" type="${datetimeType}"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="celula_relatorio" baseColumnNames="celula_id" constraintName="fk_celula_relatorio_celula" referencedTableName="celula" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="celula_relatorio" baseColumnNames="igreja_id" constraintName="fk_celula_relatorio_igreja" referencedTableName="igreja" referencedColumnNames="id"/>
        <createIndex tableName="celula_relatorio" indexName="idx_celula_relatorio_celula">
            <column name="celula_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
