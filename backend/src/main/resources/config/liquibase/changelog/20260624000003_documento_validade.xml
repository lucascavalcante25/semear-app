<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260624000003-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="documento_igreja" columnName="data_validade"/>
            </not>
        </preConditions>
        <addColumn tableName="documento_igreja">
            <column name="data_validade" type="date"/>
        </addColumn>
        <createIndex tableName="documento_igreja" indexName="idx_documento_igreja_data_validade">
            <column name="data_validade"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
