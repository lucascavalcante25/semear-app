<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260610000002-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="solicitacao_suporte_historico"/>
            </not>
        </preConditions>
        <createTable tableName="solicitacao_suporte_historico">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="solicitacao_suporte_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="usuario_id" type="bigint"/>
            <column name="acao" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="status_anterior" type="varchar(30)"/>
            <column name="status_novo" type="varchar(30)"/>
            <column name="mensagem" type="${clobType}"/>
            <column name="data_acao" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="visivel_para_cliente" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="usuario_nome" type="varchar(120)"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="solicitacao_suporte_historico"
            baseColumnNames="solicitacao_suporte_id"
            constraintName="fk_suporte_historico_solicitacao"
            referencedTableName="solicitacao_suporte"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="solicitacao_suporte_historico"
            baseColumnNames="usuario_id"
            constraintName="fk_suporte_historico_usuario"
            referencedTableName="jhi_user"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
