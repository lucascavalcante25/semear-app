<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260716000001-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="culto_ocorrencia" columnName="cancelado"/></not>
        </preConditions>
        <addColumn tableName="culto_ocorrencia">
            <column name="cancelado" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="motivo_cancelamento" type="text"/>
            <column name="cancelado_em" type="${datetimeType}"/>
            <column name="cancelado_por_id" type="bigint"/>
        </addColumn>
        <addForeignKeyConstraint
            baseTableName="culto_ocorrencia"
            baseColumnNames="cancelado_por_id"
            constraintName="fk_culto_ocorrencia_cancelado_por"
            referencedTableName="jhi_user"
            referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>
