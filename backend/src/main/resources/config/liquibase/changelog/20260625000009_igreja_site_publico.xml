<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260625000009-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="igreja" columnName="slug"/></not>
        </preConditions>
        <addColumn tableName="igreja">
            <column name="slug" type="varchar(100)"/>
            <column name="horario_culto" type="${clobType}"/>
            <column name="site_ativo" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="exibir_avisos_publicos" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addUniqueConstraint tableName="igreja" columnNames="slug" constraintName="uk_igreja_slug"/>
    </changeSet>
</databaseChangeLog>
