<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260625000001-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="informativo" columnName="cta_rotulo"/></not>
        </preConditions>
        <addColumn tableName="informativo">
            <column name="cta_rotulo" type="varchar(100)"/>
            <column name="cta_rota" type="varchar(255)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
