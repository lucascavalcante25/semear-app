<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260627000003-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="escala_config_automatica" columnName="gerar_portaria"/></not>
        </preConditions>
        <addColumn tableName="escala_config_automatica">
            <column name="gerar_portaria" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="gerar_recepcao" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="gerar_limpeza" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="agrupar_portaria_recepcao" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="limpeza_mensal" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
