<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260610000003-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="solicitacao_suporte" columnName="lida_pelo_suporte"/>
            </not>
        </preConditions>
        <addColumn tableName="solicitacao_suporte">
            <column name="lida_pelo_suporte" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260610000003-2" author="semear">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="solicitacao_suporte_mensagem"/>
            </not>
        </preConditions>
        <createTable tableName="solicitacao_suporte_mensagem">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="solicitacao_suporte_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="usuario_id" type="bigint"/>
            <column name="tipo" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="texto" type="${clobType}">
                <constraints nullable="false"/>
            </column>
            <column name="data_envio" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="usuario_nome" type="varchar(120)"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="solicitacao_suporte_mensagem"
            baseColumnNames="solicitacao_suporte_id"
            constraintName="fk_suporte_mensagem_solicitacao"
            referencedTableName="solicitacao_suporte"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="solicitacao_suporte_mensagem"
            baseColumnNames="usuario_id"
            constraintName="fk_suporte_mensagem_usuario"
            referencedTableName="jhi_user"
            referencedColumnNames="id"/>
        <createIndex tableName="solicitacao_suporte_mensagem" indexName="idx_suporte_mensagem_solicitacao">
            <column name="solicitacao_suporte_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
