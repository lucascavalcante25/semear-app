<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260626000001-1" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="crianca" columnName="sala"/></not>
        </preConditions>
        <addColumn tableName="crianca">
            <column name="sala" type="varchar(100)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260626000001-2" author="semear">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="crianca" columnName="alergias"/></not>
        </preConditions>
        <addColumn tableName="crianca">
            <column name="alergias" type="${clobType}"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
